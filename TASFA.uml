@startuml TASFA_Unified_Server_Authoritative

skinparam backgroundColor #FEFEFE
skinparam sequenceArrowThickness 2
skinparam sequenceParticipantBorderThickness 2
skinparam BoxBorderThickness 2

participant Client

box "TASFA Server" #F8F8F8
    participant API
    participant HTP
    participant Storage
end box

== Upload Init ==

Client -> API: POST /file/upload/init
API --> Client: upload_id, token, chunk_size, modulus_M

== Parallel Chunk Upload ==

loop For each chunk
    Client -> API: POST /file/upload
    note right
      Headers:
      X-TASFA-Chunk-Index
      Hash-Tag
      Raw-Scalar
      Magic-Scalar
    end note

    API -> Storage: pwrite(chunk_data)
    API -> HTP: save_htp_scalar(chunk_index)
    API --> Client: 204 Accepted
end

== Completion Request ==

Client -> API: POST /file/upload/complete
API -> HTP: load all scalars
HTP -> HTP: validate Level-0 6-slot groups

alt All groups pass
    HTP --> API: validation OK
    API -> Storage: sha256_file()
    API -> Storage: finalize commit
    API --> Client: 200 OK\n(file_id, url, checksum)

else Some groups fail

    HTP -> HTP: derive suspicion scores per slot
    HTP -> HTP: evaluate repair threshold

    alt Contraction worthwhile

        HTP -> HTP: build Level-1 group aggregates
        HTP -> HTP: validate contracted topology

        alt Contraction narrows suspects
            HTP --> API: retry_targets=[c14,c15]\ncontraction_level=1

        else Contraction inconclusive
            HTP --> API: retry_targets=all suspects\ncontraction_level=1
        end

    else Direct retry cheaper
        HTP --> API: retry_targets=all suspects\ncontraction_level=0
    end

    API --> Client: 409 needs_retry
    note right
      htp_status: needs_retry
      retry_targets: [...]
      suspicion_scores: [...]
    end note
end

== Retransmission ==

loop For each retry target
    Client -> API: POST /file/upload (retransmit)

    API -> Storage: overwrite chunk
    API -> HTP: replace scalar
    API --> Client: 204 Accepted
end

== Re-Validation ==

Client -> API: POST /file/upload/complete
API -> HTP: validate fresh topology

alt Pass
    HTP --> API: validation OK
    API -> Storage: commit file
    API --> Client: 200 OK\n(file_id, url, checksum, delete_pin)

else Still failing
    HTP -> HTP: next contraction or retry escalation
    HTP --> API: narrowed retry_targets
    API --> Client: 409 needs_retry
end

@enduml
